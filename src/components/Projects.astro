---
import siteContent from '../content';
---

<section id="projects" class="py-20 md:py-28">
  <div class="max-w-3xl mx-auto px-6">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-12">
      <h2 class="text-xl font-bold text-slate-900 whitespace-nowrap">Projects</h2>
      <div class="h-px flex-1 bg-slate-200" aria-hidden="true"></div>
    </div>

    <div class="space-y-12">
      {siteContent.projects.map((project) => (
        <article>
          <!-- Name + links row -->
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2 mb-1">
            <h3 class="text-base font-semibold text-slate-900">{project.name}</h3>
            <div class="flex flex-wrap gap-4 shrink-0">
              {project.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-blue-600 hover:text-blue-700 hover:underline underline-offset-2"
                >
                  {link.label} ↗
                </a>
              ))}
            </div>
          </div>

          <!-- One-liner -->
          <p class="text-sm text-slate-500 mb-2">{project.description}</p>

          <!-- Details paragraph -->
          <p class="text-sm text-slate-700 leading-relaxed mb-3">{project.details}</p>

          <!-- Tech tags -->
          <div class="flex flex-wrap gap-2">
            {project.tech.map((tag) => (
              <span class="text-xs font-mono bg-slate-100 text-slate-600 px-2.5 py-1 rounded">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
