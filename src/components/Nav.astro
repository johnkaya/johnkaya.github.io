---
import siteContent from '../content';

const navLinks = [
  { label: 'About',      href: '#about' },
  { label: 'Experience', href: '#experience' },
  { label: 'Projects',   href: '#projects' },
  { label: 'Contact',    href: '#contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-200">
  <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Name / logo -->
    <a
      href="#top"
      class="text-sm font-semibold tracking-wide text-slate-900 hover:text-blue-600 transition-colors"
    >
      {siteContent.name}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-7" aria-label="Primary">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="text-sm text-slate-600 hover:text-blue-600 transition-colors"
        >
          {label}
        </a>
      ))}
      <a
        href={siteContent.resumeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm px-4 py-1.5 rounded border border-blue-600 text-blue-600 hover:bg-blue-600 hover:text-white transition-colors font-medium"
      >
        Resume ↗
      </a>
    </nav>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 -mr-2 text-slate-600 hover:text-slate-900 transition-colors"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <!-- Hamburger icon -->
      <svg
        id="icon-menu"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6"  x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <!-- Close icon -->
      <svg
        id="icon-close"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="hidden"
        aria-hidden="true"
      >
        <line x1="18" y1="6"  x2="6"  y2="18" />
        <line x1="6"  y1="6"  x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200">
    <nav class="max-w-4xl mx-auto px-6 py-5 flex flex-col gap-5" aria-label="Mobile primary">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="text-sm text-slate-700 hover:text-blue-600 transition-colors mobile-nav-link"
        >
          {label}
        </a>
      ))}
      <a
        href={siteContent.resumeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-blue-600 hover:text-blue-700 font-medium"
      >
        Resume ↗
      </a>
    </nav>
  </div>
</header>

<script>
  const btn    = document.getElementById('mobile-menu-btn')!;
  const menu   = document.getElementById('mobile-menu')!;
  const iMenu  = document.getElementById('icon-menu')!;
  const iClose = document.getElementById('icon-close')!;

  function closeMenu() {
    menu.classList.add('hidden');
    iMenu.classList.remove('hidden');
    iClose.classList.add('hidden');
    btn.setAttribute('aria-expanded', 'false');
  }

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    if (isOpen) {
      closeMenu();
    } else {
      menu.classList.remove('hidden');
      iMenu.classList.add('hidden');
      iClose.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
    }
  });

  // Close when any mobile nav link is clicked
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
