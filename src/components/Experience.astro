---
import siteContent from '../content';

/** Converts [label](url) markdown links inside bullet strings to anchor tags. */
function parseLinks(text: string): string {
  return text.replace(
    /\[([^\]]+)\]\(([^)]+)\)/g,
    '<a href="$2" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-700 underline underline-offset-2">$1</a>'
  );
}
---

<section id="experience" class="py-20 md:py-28 bg-slate-50">
  <div class="max-w-3xl mx-auto px-6">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-12">
      <h2 class="text-xl font-bold text-slate-900 whitespace-nowrap">Experience</h2>
      <div class="h-px flex-1 bg-slate-200" aria-hidden="true"></div>
    </div>

    <div class="space-y-14">
      {siteContent.experience.map((item) => (
        <article>
          <!-- Company / role / dates -->
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-base font-semibold text-slate-900 hover:text-blue-600 transition-colors"
              >
                {item.company}
              </a>
              <span class="text-slate-300" aria-hidden="true">·</span>
              <span class="text-slate-700 font-medium text-base">{item.role}</span>
            </div>
            <span class="text-sm text-slate-400 font-mono whitespace-nowrap shrink-0">{item.dates}</span>
          </div>

          {item.context && (
            <p class="text-sm text-slate-500 italic mb-3">{item.context}</p>
          )}

          <!-- Bullets -->
          <ul class="space-y-2.5 mt-3">
            {item.bullets.map((bullet) => (
              <li class="flex gap-3 text-slate-700 leading-relaxed text-sm">
                <span class="text-blue-400 mt-1 shrink-0 select-none" aria-hidden="true">—</span>
                <span set:html={parseLinks(bullet)} />
              </li>
            ))}
          </ul>

          <!-- Tech tags -->
          {item.tech && item.tech.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {item.tech.map((tag) => (
                <span class="text-xs font-mono bg-slate-100 text-slate-600 px-2.5 py-1 rounded">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- External links -->
          {item.links && item.links.filter(l => l.url).length > 0 && (
            <div class="flex flex-wrap gap-5 mt-4">
              {item.links.filter(l => l.url).map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-blue-600 hover:text-blue-700 hover:underline underline-offset-2"
                >
                  {link.label} ↗
                </a>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
