---
import siteContent from '../content';
---

<section id="about" class="py-20 md:py-28">
  <div class="max-w-3xl mx-auto px-6">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-10">
      <h2 class="text-xl font-bold text-slate-900 whitespace-nowrap">About</h2>
      <div class="h-px flex-1 bg-slate-200" aria-hidden="true"></div>
    </div>

    <div class="max-w-2xl">
      <p class="text-slate-700 leading-relaxed text-base whitespace-pre-line">
        {siteContent.about}
      </p>
    </div>
  </div>
</section>
